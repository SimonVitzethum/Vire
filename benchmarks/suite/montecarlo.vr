fn main() {
    mut seed = 12345
    mut inside = 0
    mut i = 0
    while i < 20000000 {
        seed = (seed * 1103515245 + 12345) % 2147483648
        mut x = seed % 10000
        seed = (seed * 1103515245 + 12345) % 2147483648
        mut y = seed % 10000
        if x * x + y * y < 100000000 { inside = inside + 1 }
        i = i + 1
    }
    print(inside)
}
