fn main() {
    mut n = 20000000
    mut flags = array(n)
    mut i = 2
    while i < n { flags[i] = 1
        i = i + 1 }
    mut count = 0
    mut p = 2
    while p < n {
        if flags[p] == 1 {
            count = count + 1
            mut k = p + p
            while k < n { flags[k] = 0
                k = k + p }
        }
        p = p + 1
    }
    print(count)
}
