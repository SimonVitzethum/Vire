# cuda-oxide generated files (regenerated by cargo oxide run)
mathdx_ffi_test.ll
mathdx_ffi_test.ltoir
merged.cubin

# nvcc intermediate files (cleaned by build.sh)
*.ii
*.cudafe*
*.fatbin
*.fatbin.c
*.module_id
*.ptx
*.gpu
*.o

# Compiled test binaries
extern-libs/test_separate
extern-libs/*.cubin

# LTOIR files (both binary and text are too large for git)
extern-libs/*.ltoir
extern-libs/*_text.ltoir

# Cargo build artifacts
target/

# Bug documentation (local debugging notes, not for version control)
bugs/

# Summary - files we KEEP in extern-libs/:
#   *.cu          - CUDA C++ source files
#   *.sh          - Build scripts
#   README.md     - Documentation
#
# Files regenerated by build.sh (not tracked):
#   *.ltoir       - Binary LTOIR for nvJitLink
#   *_text.ltoir  - Text LTOIR (too large for git)
