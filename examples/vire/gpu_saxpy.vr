// index `i` is the injected global thread index (param 0), like a parallel_for worker
@gpu
fn saxpy(i: Int, n: Int, a: Int, x: array, y: array) {
    if i < n { y[i] = a * x[i] + y[i] }
}
fn main() {
    mut x = array(1000)
    mut y = array(1000)
    mut i = 0
    while i < 1000 { x[i] = i  y[i] = 2 * i  i = i + 1 }
    saxpy(1000, 3, x, y)
    mut ok = 1
    mut j = 0
    while j < 1000 { if y[j] != 5 * j { ok = 0 } j = j + 1 }
    print(ok)
    print(y[7])
}
