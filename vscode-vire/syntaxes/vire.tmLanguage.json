{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Vire",
    "scopeName": "source.vire",
    "patterns": [
        { "include": "#comments" },
        { "include": "#attributes" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#keywords" },
        { "include": "#types" },
        { "include": "#gpu" },
        { "include": "#function-def" },
        { "include": "#function-call" },
        { "include": "#operators" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.vire",
                    "begin": "//",
                    "end": "$"
                },
                {
                    "name": "comment.block.vire",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "attributes": {
            "patterns": [
                {
                    "name": "meta.attribute.vire",
                    "match": "@(derive|when|gpu|c|asm)\\b",
                    "captures": {
                        "0": { "name": "entity.name.function.decorator.vire" }
                    }
                },
                {
                    "name": "meta.attribute.vire",
                    "match": "@[A-Za-z_][A-Za-z0-9_]*",
                    "captures": {
                        "0": { "name": "entity.name.function.decorator.vire" }
                    }
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.triple.vire",
                    "begin": "\"\"\"",
                    "end": "\"\"\""
                },
                {
                    "name": "string.quoted.double.vire",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        { "name": "constant.character.escape.vire", "match": "\\\\." }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                { "name": "constant.numeric.float.vire", "match": "\\b[0-9][0-9_]*\\.[0-9_]+([eE][+-]?[0-9]+)?\\b" },
                { "name": "constant.numeric.hex.vire", "match": "\\b0x[0-9a-fA-F_]+\\b" },
                { "name": "constant.numeric.binary.vire", "match": "\\b0b[01_]+\\b" },
                { "name": "constant.numeric.integer.vire", "match": "\\b[0-9][0-9_]*\\b" }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.vire",
                    "match": "\\b(match|if|elif|else|while|for|in|break|continue|return|spawn)\\b"
                },
                {
                    "name": "keyword.declaration.vire",
                    "match": "\\b(fn|type|trait|impl|mut|const|use|pub|extern|unsafe|macro|comptime|capsule|native)\\b"
                },
                {
                    "name": "keyword.operator.word.vire",
                    "match": "\\b(and|or|not|as)\\b"
                },
                {
                    "name": "constant.language.vire",
                    "match": "\\b(true|false|null)\\b"
                },
                {
                    "name": "variable.language.vire",
                    "match": "\\b(self|Self)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "support.type.primitive.vire",
                    "match": "\\b(Int|Float|Bool|Str|Void|I32|I64|U32|F32|F64)\\b"
                },
                {
                    "name": "support.type.builtin.vire",
                    "match": "\\b(Array|Map|List|Set|Option|Result|Atomic|Mutex|Channel|array|farray|list|map|set)\\b"
                },
                {
                    "name": "entity.name.type.vire",
                    "match": "\\b([A-Z][A-Za-z0-9_]*)\\b"
                }
            ]
        },
        "gpu": {
            "patterns": [
                {
                    "name": "support.function.gpu.vire",
                    "match": "\\b(gpu_gid|gpu_gsize|gpu_tid|gpu_bid|gpu_bdim|gpu_gdim)\\b"
                }
            ]
        },
        "function-def": {
            "match": "\\b(fn)\\s+([a-z_][A-Za-z0-9_]*)",
            "captures": {
                "1": { "name": "keyword.declaration.vire" },
                "2": { "name": "entity.name.function.vire" }
            }
        },
        "function-call": {
            "patterns": [
                {
                    "name": "support.function.builtin.vire",
                    "match": "\\b(print|str|len|join|parallel_for|spawn)\\s*(?=\\()"
                },
                {
                    "match": "\\b([a-z_][A-Za-z0-9_]*)\\s*(?=\\()",
                    "captures": {
                        "1": { "name": "entity.name.function.call.vire" }
                    }
                }
            ]
        },
        "operators": {
            "patterns": [
                { "name": "keyword.operator.arrow.vire", "match": "->|=>" },
                { "name": "keyword.operator.propagation.vire", "match": "\\?" },
                { "name": "keyword.operator.range.vire", "match": "\\.\\.=?" },
                { "name": "keyword.operator.comparison.vire", "match": "==|!=|<=|>=|<|>" },
                { "name": "keyword.operator.assignment.vire", "match": "=" },
                { "name": "keyword.operator.arithmetic.vire", "match": "[+\\-*/%]|<<|>>|&|\\||\\^" }
            ]
        }
    }
}
